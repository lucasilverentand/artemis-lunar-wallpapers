---
import Layout from "../layouts/Layout.astro";
import images from "../data/images.json";

const base = import.meta.env.BASE_URL;

const devices = [
  { label: "5K Desktop", slug: "5k", w: 5120, h: 2880, type: "desktop" },
  { label: "4K Desktop", slug: "4k", w: 3840, h: 2160, type: "desktop" },
  { label: "1080p Desktop", slug: "1080p", w: 1920, h: 1080, type: "desktop" },
  { label: "iPhone 16 Pro Max", slug: "iphone-16-pro-max", w: 1320, h: 2868, type: "phone" },
  { label: "iPhone 16 Pro", slug: "iphone-16-pro", w: 1206, h: 2622, type: "phone" },
  { label: "iPhone 16", slug: "iphone-16", w: 1179, h: 2556, type: "phone" },
  { label: "iPhone SE", slug: "iphone-se", w: 750, h: 1334, type: "phone" },
  { label: "Galaxy S24 Ultra", slug: "samsung-galaxy-s24-ultra", w: 1440, h: 3120, type: "phone" },
  { label: "Pixel 9 Pro", slug: "google-pixel-9-pro", w: 1344, h: 2992, type: "phone" },
];
---

<Layout
  title="Lunar Wallpapers"
  description="Free high-resolution wallpapers from the Artemis II mission. Available for desktop and phone."
>
  <!-- Hero -->
  <header class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-lunar-950 via-transparent to-lunar-950 z-10"></div>
    <div class="absolute inset-0 bg-[url('/artemis-lunar-desktop/thumbnails/total-solar-eclipse-corona.jpg')] bg-cover bg-center opacity-30 blur-sm scale-105"></div>
    <div class="relative z-20 flex flex-col items-center justify-center min-h-[85vh] px-8 text-center">
      <p class="text-lunar-400 font-mono text-sm tracking-[0.3em] uppercase mb-4">NASA Artemis II</p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-light tracking-tight text-white mb-6">
        Lunar Wallpapers
      </h1>
      <p class="text-lunar-300 text-lg md:text-xl max-w-2xl leading-relaxed">
        {"Photos taken by the Artemis II crew during their lunar flyby, cropped and resized into free wallpapers for every screen."}
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm font-mono">
        <span class="px-3 py-1.5 rounded-full border border-lunar-700 text-lunar-400"><span id="stat-views">-</span> views</span>
        <span class="px-3 py-1.5 rounded-full border border-lunar-700 text-lunar-400"><span id="stat-downloads">-</span> downloads</span>
        <span class="px-3 py-1.5 rounded-full border border-lunar-700 text-lunar-400">{images.length} images</span>
      </div>

      <!-- Device selector -->
      <div class="mt-8 w-full max-w-xs">
        <label for="device-select" class="text-lunar-500 text-xs font-mono uppercase tracking-widest mb-2 block">Choose your device</label>
        <select
          id="device-select"
          class="w-full bg-lunar-800/80 border border-lunar-600 text-white text-sm rounded-lg px-4 py-3 appearance-none cursor-pointer focus:outline-none focus:border-lunar-400 transition-colors backdrop-blur-sm"
        >
          <optgroup label="Desktop">
            {devices.filter(d => d.type === "desktop").map((d) => (
              <option
                value={d.slug}
                data-w={d.w}
                data-h={d.h}
                data-type={d.type}
              >
                {d.label} ({d.w} x {d.h})
              </option>
            ))}
          </optgroup>
          <optgroup label="Phone">
            {devices.filter(d => d.type === "phone").map((d) => (
              <option
                value={d.slug}
                data-w={d.w}
                data-h={d.h}
                data-type={d.type}
              >
                {d.label} ({d.w} x {d.h})
              </option>
            ))}
          </optgroup>
        </select>
      </div>

      <a href="#gallery" class="mt-10 text-lunar-400 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </header>

  <!-- Gallery -->
  <main id="gallery" class="max-w-[1600px] mx-auto px-4 md:px-8 pb-24">
    <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {images.map((image) => (
        <button
          class="gallery-card group relative rounded-lg overflow-hidden cursor-pointer border-0 bg-lunar-900 p-0 text-left"
          data-name={image.name}
          data-title={image.title}
          data-description={image.description}
          data-credit={image.credit}
          data-camera={image.camera}
          data-date={image.date}
          data-id={image.id}
        >
          <img
            src={`${base}thumbnails/${image.name}.jpg`}
            alt={image.description}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/0 to-transparent opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="text-white text-sm font-medium">{image.title}</h3>
              <p class="text-lunar-300 text-xs mt-1">{image.caption}</p>
              <div class="flex items-center justify-between mt-1.5">
                <p class="text-lunar-500 text-[10px] font-mono">{image.credit} · {image.id}</p>
                <span class="download-count text-lunar-500 text-[10px] font-mono" data-image={image.name}></span>
              </div>
            </div>
          </div>
        </button>
      ))}
    </div>
  </main>

  <!-- Preview + Download Modal -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center p-safe">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/90 backdrop-blur-sm"></div>
    <div class="relative flex flex-col items-center w-full max-w-4xl mx-4 max-h-[92vh]">
      <!-- Close -->
      <button id="modal-close" class="absolute -top-1 -right-1 z-10 text-lunar-400 hover:text-white transition-colors p-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Preview image -->
      <div class="flex items-center justify-center flex-1 min-h-0 w-full mb-4">
        <img id="preview-img" src="" alt="" class="rounded-xl shadow-2xl object-cover transition-all duration-300" />
      </div>

      <!-- Image info -->
      <div class="w-full mb-4 text-center">
        <h2 id="modal-title" class="text-white text-lg font-medium"></h2>
        <p id="modal-desc" class="text-lunar-400 text-sm mt-1 max-w-xl mx-auto line-clamp-2"></p>
        <p id="modal-meta" class="text-lunar-500 text-xs mt-2 font-mono"></p>
      </div>

      <!-- Download button -->
      <button id="download-btn" class="flex items-center justify-center gap-3 bg-white text-lunar-950 font-semibold px-10 py-4 rounded-xl hover:bg-lunar-100 active:scale-[0.97] transition-all text-base min-w-[200px]">
        <span id="download-label" class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download Wallpaper
        </span>
        <span id="download-spinner" class="hidden flex items-center gap-3">
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
          </svg>
          Downloading...
        </span>
      </button>
    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-lunar-800 py-12 text-center">
    <p class="text-lunar-500 text-sm">
      Images from the <a href="https://www.nasa.gov/gallery/lunar-flyby/" class="text-lunar-300 hover:text-white underline underline-offset-2 transition-colors">NASA Artemis II Lunar Flyby Gallery</a>.
      Free for personal use.
    </p>
    <p class="text-lunar-600 text-xs mt-2">
      Built by <a href="https://github.com/lucasilverentand" class="hover:text-lunar-400 transition-colors">Luca Silverentand</a>
    </p>
  </footer>

  <div id="app-data" data-base={base} data-api="https://artemis-lunar-analytics.seventwo.workers.dev" class="hidden"></div>
  <script>
    const appData = document.getElementById("app-data")!;
    const base = appData.dataset.base!;
    const API = appData.dataset.api!;
    const modal = document.getElementById("modal")!;
    const modalClose = document.getElementById("modal-close")!;
    const modalBackdrop = document.getElementById("modal-backdrop")!;
    const previewImg = document.getElementById("preview-img") as HTMLImageElement;
    const deviceSelect = document.getElementById("device-select") as HTMLSelectElement;
    const downloadBtn = document.getElementById("download-btn")!;
    const downloadLabel = document.getElementById("download-label")!;
    const downloadSpinner = document.getElementById("download-spinner")!;
    const modalTitle = document.getElementById("modal-title")!;
    const modalDesc = document.getElementById("modal-desc")!;
    const modalMeta = document.getElementById("modal-meta")!;
    const galleryCards = document.querySelectorAll<HTMLButtonElement>(".gallery-card");

    let currentName = "";

    function getDevice() {
      const opt = deviceSelect.selectedOptions[0];
      return {
        slug: deviceSelect.value,
        w: Number(opt.dataset.w),
        h: Number(opt.dataset.h),
        type: opt.dataset.type as "desktop" | "phone",
      };
    }

    function updateCardAspectRatios() {
      const { w, h } = getDevice();
      const ratio = w / h;
      galleryCards.forEach((card) => {
        card.style.aspectRatio = String(ratio);
      });
    }

    function getDownloadUrl(name: string) {
      const device = getDevice();
      return base + "wallpapers/" + name + "/" + device.type + "/" + name + "-" + device.slug + ".jpg";
    }

    function openModal(card: HTMLButtonElement) {
      const name = card.dataset.name!;
      currentName = name;
      const device = getDevice();
      const ratio = device.w / device.h;

      previewImg.src = base + "thumbnails/" + name + ".jpg";
      previewImg.alt = card.dataset.title || name.replace(/-/g, " ");
      previewImg.style.aspectRatio = String(ratio);

      if (ratio > 1) {
        previewImg.style.maxHeight = "65vh";
        previewImg.style.maxWidth = "100%";
      } else {
        previewImg.style.maxHeight = "60vh";
        previewImg.style.maxWidth = "min(100%, 45vh)";
      }
      previewImg.style.width = "auto";
      previewImg.style.height = "auto";

      modalTitle.textContent = card.dataset.title || name.replace(/-/g, " ");
      modalDesc.textContent = card.dataset.description || "";

      const parts: string[] = [];
      if (card.dataset.credit) parts.push(card.dataset.credit);
      if (card.dataset.camera) parts.push(card.dataset.camera);
      if (card.dataset.date) {
        const d = new Date(card.dataset.date);
        if (d.getUTCHours() !== 0 || d.getUTCMinutes() !== 0) {
          parts.push(d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) + " " + d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }));
        } else {
          parts.push(d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }));
        }
      }
      if (card.dataset.id) parts.push(card.dataset.id);
      modalMeta.textContent = parts.join(" \u00b7 ");

      downloadBtn.dataset.url = getDownloadUrl(name);

      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
      currentName = "";
    }

    async function downloadImage(url: string, filename: string) {
      downloadLabel.classList.add("hidden");
      downloadSpinner.classList.remove("hidden");
      try {
        const res = await fetch(url);
        const blob = await res.blob();
        const blobUrl = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = blobUrl;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(blobUrl);
      } catch {
        window.open(url, "_blank");
      }
      downloadSpinner.classList.add("hidden");
      downloadLabel.classList.remove("hidden");
    }

    // Device change updates all card ratios
    deviceSelect.addEventListener("change", updateCardAspectRatios);

    // Download
    downloadBtn.addEventListener("click", () => {
      const url = downloadBtn.dataset.url;
      if (!url) return;
      const filename = url.split("/").pop() || "wallpaper.jpg";
      const device = getDevice();
      trackDownload(currentName, device.slug);
      downloadImage(url, filename);
    });

    // Card click opens modal
    galleryCards.forEach((card) => {
      card.addEventListener("click", () => {
        openModal(card);
      });
    });

    modalClose.addEventListener("click", closeModal);
    modalBackdrop.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });

    // Set initial aspect ratios
    updateCardAspectRatios();

    // --- Analytics (fire and forget, no cookies, fully anonymous) ---

    function trackView() {
      fetch(API + "/view", { method: "POST" }).catch(() => {});
    }

    function trackDownload(image: string, device: string) {
      fetch(API + "/download", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image, device }),
      }).catch(() => {});
    }

    async function loadStats() {
      try {
        const res = await fetch(API + "/stats");
        const data = await res.json() as {
          views: number;
          totalDownloads: number;
          downloads: Record<string, number>;
        };

        const viewsEl = document.getElementById("stat-views");
        const dlEl = document.getElementById("stat-downloads");
        if (viewsEl) viewsEl.textContent = data.views.toLocaleString();
        if (dlEl) dlEl.textContent = data.totalDownloads.toLocaleString();

        document.querySelectorAll<HTMLSpanElement>(".download-count").forEach((el) => {
          const name = el.dataset.image;
          if (name && data.downloads[name]) {
            el.textContent = data.downloads[name].toLocaleString() + " downloads";
          }
        });
      } catch {}
    }

    trackView();
    loadStats();
  </script>
</Layout>
